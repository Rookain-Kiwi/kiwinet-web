---
/**
 * en/projects.astro
 * Role  : Projects page (English version) — lists built and maintained projects
 *         (Kiwinet infra, ECF Infoline, Minecraft server) with status, description,
 *         technology tags and links.
 * Props : none (static page)
 * Emits : none
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar     from "../../components/Navbar.astro";
import Footer     from "../../components/Footer.astro";

const lang = "en";

const projects = [
  {
    id: "kiwinet",
    icon: "grid",
    iconBg: "#EEEDFE",
    title: "Kiwinet: Self-hosted infrastructure",
    subtitle: "Debian VM · ARM AArch64 · Freebox Delta",
    status: "In production",
    statusClass: "status-live",
    desc: "This site and the infrastructure running it are themselves a project. From the Debian ARM VM to the monitoring stack, everything is self-hosted, versioned and deployed through a complete DevOps pipeline.",
    tags: ["Traefik", "Docker", "GitHub Actions", "Astro", "Nginx", "Prometheus", "Grafana", "Loki", "ARM AArch64"],
    services: ["Kiwinet.me", "status.kiwinet.me", "grafana.kiwinet.me", "plex.kiwinet.me"],
    link: { label: "View the stack", href: "/en/stack" },
  },
  {
    id: "ecf",
    icon: "star",
    iconBg: "#FAEEDA",
    title: "ECF Infoline: Studi training project",
    subtitle: "AWS · Kubernetes · Terraform · Spring Boot · Angular",
    status: "Initial submission, improvements ongoing",
    statusClass: "status-wip",
    desc: "End-of-training project completed as part of the ECF Infoline programme with Studi. Infrastructure as Code on AWS EKS + RDS + Lambda, Java Spring Boot REST API and Angular application, deployed via GitHub Actions.",
    tags: ["AWS EKS", "Terraform", "Kubernetes", "GitHub Actions", "Spring Boot", "Angular", "RDS", "Lambda", "ECR", "ELK Stack"],
    services: [],
    link: { label: "View repositories", href: "https://github.com/stars/Rookain-Kiwi/lists/infoline", external: true },
    note: "Available on GitHub",
  },
  {
    id: "minecraft",
    icon: "server",
    iconBg: "#E1F5EE",
    title: "Minecraft Server",
    subtitle: "Vanilla · Invite-only",
    status: "On request",
    statusClass: "status-open",
    desc: "Vanilla Minecraft server hosted on the same VM as the rest of the infrastructure. Access is invite-only — join the Discord to request an invitation.",
    tags: [],
    services: [],
    address: "minecraft.kiwinet.me",
    discord: "https://discord.gg/Ud53YtjZ",
  },
];
---

<BaseLayout
  title="Projects — Loïc Kergoat"
  description="Projects built, hosted and maintained by Loïc Kergoat: Kiwinet, ECF Infoline, Minecraft server."
  lang={lang}
>
  <Navbar lang={lang} currentPath="/en/projects" />

  <main class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="page-lead">Projects built, hosted and maintained end to end.</p>
    </header>

    <div class="projects-list">
      {projects.map((p) => (
        <article class="proj-card">

          <div class="proj-top">
            <div class="proj-title-block">
              <div class="proj-icon" style={`background:${p.iconBg};`}>
                {p.icon === "grid" && (
                  <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="6" height="6" rx="1.5" fill="#534AB7"/>
                    <rect x="10" y="2" width="6" height="6" rx="1.5" fill="#AFA9EC"/>
                    <rect x="2" y="10" width="6" height="6" rx="1.5" fill="#AFA9EC"/>
                    <rect x="10" y="10" width="6" height="6" rx="1.5" fill="#534AB7"/>
                  </svg>
                )}
                {p.icon === "star" && (
                  <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M9 2L11.5 7H16L12.5 10.5L14 15L9 12.5L4 15L5.5 10.5L2 7H6.5L9 2Z" fill="#BA7517"/>
                  </svg>
                )}
                {p.icon === "server" && (
                  <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <rect x="2" y="6" width="14" height="9" rx="1.5" fill="#1D9E75"/>
                    <rect x="5" y="3" width="8" height="5" rx="1" fill="#5DCAA5"/>
                    <circle cx="9" cy="10.5" r="1.5" fill="white"/>
                  </svg>
                )}
              </div>
              <div>
                <h2 class="proj-title">{p.title}</h2>
                <p class="proj-subtitle">{p.subtitle}</p>
              </div>
            </div>
            <span class={`proj-status ${p.statusClass}`}>{p.status}</span>
          </div>

          <p class="proj-desc">{p.desc}</p>

          {p.tags.length > 0 && (
            <ul class="proj-tags" role="list">
              {p.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )}

          <div class="proj-footer">
            {p.services && p.services.length > 0 && (
              <ul class="proj-services" role="list">
                {p.services.map((s) => (
                  <li class="service-badge">{s}</li>
                ))}
              </ul>
            )}

            {p.address && (
              <div class="proj-info-row">
                <span class="info-label">Address</span>
                <span class="info-sep" aria-hidden="true">·</span>
                <code class="info-address">{p.address}</code>
                <span class="info-sep" aria-hidden="true">·</span>
                <a href={p.discord} target="_blank" rel="noopener noreferrer" class="info-link">
                  Join the Discord
                </a>
              </div>
            )}

            {p.link && (
              <div class="proj-link-wrap">
                {p.note && <span class="proj-note">{p.note}</span>}
                <a
                  href={p.link.href}
                  class="proj-link"
                  {...(p.link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {p.link.label}
                  <svg viewBox="0 0 12 12" fill="none" aria-hidden="true" class="proj-link-icon">
                    <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                </a>
              </div>
            )}
          </div>

        </article>
      ))}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
/* ─── Layout ──────────────────────────────────────────────────────────────── */
main {
  padding-top: 3rem;
  padding-bottom: 4rem;
}

.page-header {
  margin-bottom: 2rem;
}

.page-header h1 {
  font-size: 2rem;
  font-weight: 500;
  color: var(--color-text);
  margin: 0 0 0.375rem;
}

.page-lead {
  font-size: 0.9375rem;
  color: var(--color-text-muted);
  margin: 0;
}

.projects-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* ─── Card ────────────────────────────────────────────────────────────────── */
.proj-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 1.25rem;
  transition: border-color 0.15s;
}

.proj-card:hover {
  border-color: var(--color-border-hover);
}

/* ─── En-tête card ────────────────────────────────────────────────────────── */
.proj-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 0.75rem;
}

.proj-title-block {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.proj-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.proj-icon svg {
  width: 18px;
  height: 18px;
}

.proj-title {
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-text);
  margin: 0;
  line-height: 1.3;
}

.proj-subtitle {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  margin: 2px 0 0;
}

/* ─── Badges statut ───────────────────────────────────────────────────────── */
.proj-status {
  font-size: 0.6875rem;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-live { background: #EAF3DE; color: #3B6D11; }
.status-wip  { background: #FAEEDA; color: #854F0B; }
.status-open { background: #E6F1FB; color: #185FA5; }

/* ─── Description ─────────────────────────────────────────────────────────── */
.proj-desc {
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
  line-height: 1.65;
  margin: 0 0 0.875rem;
}

/* ─── Tags ────────────────────────────────────────────────────────────────── */
.proj-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  list-style: none;
  padding: 0;
  margin: 0 0 0.875rem;
}

.tag {
  font-size: 0.6875rem;
  font-weight: 500;
  padding: 3px 8px;
  border-radius: 6px;
  background: var(--color-tag-bg);
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
}

/* ─── Footer card ─────────────────────────────────────────────────────────── */
.proj-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  padding-top: 0.75rem;
  border-top: 1px solid var(--color-border);
}

/* ─── Badges services ─────────────────────────────────────────────────────── */
.proj-services {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  list-style: none;
  padding: 0;
  margin: 0;
}

.service-badge {
  font-size: 0.6875rem;
  padding: 3px 8px;
  border-radius: 6px;
  background: #EEEDFE;
  color: #534AB7;
  border: 1px solid #AFA9EC;
  font-family: var(--font-mono, monospace);
}

/* ─── Infos Minecraft ─────────────────────────────────────────────────────── */
.proj-info-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.info-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-text);
}

.info-sep {
  font-size: 0.75rem;
  color: var(--color-border-hover);
}

.info-address {
  font-family: var(--font-mono, monospace);
  font-size: 0.75rem;
  color: var(--color-text-secondary);
}

.info-link {
  font-size: 0.75rem;
  color: var(--color-accent);
  text-decoration: none;
}

.info-link:hover {
  text-decoration: underline;
}

/* ─── Lien GitHub / Stack ─────────────────────────────────────────────────── */
.proj-link-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: auto;
}

.proj-note {
  font-size: 0.75rem;
  color: var(--color-text-muted);
}

.proj-link {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 4px;
  transition: color 0.15s;
}

.proj-link:hover {
  color: var(--color-text);
}

.proj-link-icon {
  width: 12px;
  height: 12px;
}

/* ─── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 600px) {
  .proj-top {
    flex-wrap: wrap;
  }

  .proj-status {
    margin-left: 46px;
  }

  .proj-footer {
    flex-direction: column;
    align-items: flex-start;
  }

  .proj-link-wrap {
    margin-left: 0;
  }
}
</style>
