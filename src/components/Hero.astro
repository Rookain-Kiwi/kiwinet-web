---
/**
 * Hero.astro
 * Rôle : Bannière principale de la page d'accueil — effet cyber avec animations glitch, scanlines et sweep lumineux.
 * Reçoit : lang?: "fr" | "en" — langue d'affichage (défaut : "fr")
 * Émet   : aucun
 */
interface Props {
  lang?: "fr" | "en";
}

const { lang = "fr" } = Astro.props;
---

<section class="banner" aria-label="Bannière KIWINET.ME">
  <!-- Calques décoratifs -->
  <div class="banner__bg-art"   aria-hidden="true"></div>
  <div class="banner__scanlines" aria-hidden="true"></div>
  <div class="banner__noise"    aria-hidden="true"></div>
  <div class="banner__sweep"    aria-hidden="true"></div>
  <div class="banner__hud"      aria-hidden="true"></div>
  <div class="banner__corner banner__corner--left"  aria-hidden="true"></div>
  <div class="banner__corner banner__corner--right" aria-hidden="true"></div>

  <!-- Contenu centré -->
  <div class="banner__content">
    <div>
      <div class="banner__title-wrap">
        <h1 class="banner__title" data-text="KIWINET.ME">KIWINET.ME</h1>
        <div class="banner__accent" aria-hidden="true"></div>
      </div>
      <p class="banner__subtitle">DevOps, Gaming and... Kiwis</p>
    </div>
  </div>
</section>

<style>
/* ── Variables locales ──────────────────────────────────────────── */
.banner {
  --kiwi:      #8dfc3c;
  --kiwi-2:    #6dff9f;
  --kiwi-3:    #c4ff78;
  --text:      #d9ffd0;
  --muted:     rgba(217,255,208,0.82);

  /* Dimensions */
  position: relative;
  width: 100%;
  /* ratio 16/5 avec un plancher sur mobile */
  aspect-ratio: 16 / 5;
  min-height: 180px;
  max-height: 420px;

  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0)),
    linear-gradient(135deg, rgba(141,252,60,0.05), transparent 35%),
    linear-gradient(0deg, rgba(0,0,0,0.28), rgba(0,0,0,0.28));
  border-top:    1px solid rgba(141,252,60,0.18);
  border-bottom: 1px solid rgba(141,252,60,0.18);
  overflow: hidden;
  isolation: isolate;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.02) inset,
    0 30px 80px rgba(0,0,0,0.35),
    0 0 40px rgba(141,252,60,0.06);
}

/* ── Calque d'art génératif (fond temporaire) ───────────────────── */
.banner__bg-art {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 14% 50%, rgba(141,252,60,0.10), transparent 20%),
    radial-gradient(circle at 70% 52%, rgba(109,255,159,0.08), transparent 17%),
    linear-gradient(115deg, transparent 0 15%, rgba(141,252,60,0.08) 15.4%, transparent 16.1%),
    linear-gradient(115deg, transparent 0 20%, rgba(141,252,60,0.06) 20.4%, transparent 21.1%),
    linear-gradient(90deg,  transparent 0 82%, rgba(141,252,60,0.10) 82.3%, transparent 82.7%),
    linear-gradient(0deg,   transparent 0 88%, rgba(255,255,255,0.06) 88.2%, transparent 88.5%);
  opacity: 0.95;
  pointer-events: none;
}

.banner__bg-art::before {
  content: "";
  position: absolute;
  left: 0; top: 10%;
  width: 38%; height: 80%;
  background:
    linear-gradient(135deg, rgba(141,252,60,0.14), rgba(141,252,60,0.02)),
    linear-gradient(90deg,  rgba(255,255,255,0.04), transparent 40%);
  clip-path: polygon(0 14%, 82% 0, 100% 16%, 50% 100%, 0 78%);
  filter: blur(0.6px);
  opacity: 0.55;
  pointer-events: none;
}

.banner__bg-art::after {
  content: "";
  position: absolute;
  right: -6%; bottom: -18%;
  width: 34%; height: 105%;
  background:
    linear-gradient(135deg, rgba(141,252,60,0.12), transparent 58%),
    linear-gradient(180deg, rgba(255,255,255,0.04), transparent 28%);
  clip-path: polygon(34% 0, 100% 0, 74% 100%, 0 84%);
  opacity: 0.35;
  transform: rotate(-6deg);
  pointer-events: none;
}

/* ── Effets d'ambiance ──────────────────────────────────────────── */
.banner__scanlines,
.banner__noise,
.banner__sweep {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.banner__scanlines {
  background: repeating-linear-gradient(
    to bottom,
    rgba(255,255,255,0.035) 0px,
    rgba(255,255,255,0.035) 1px,
    rgba(0,0,0,0) 2px,
    rgba(0,0,0,0) 4px
  );
  opacity: 0.11;
  mix-blend-mode: screen;
}

.banner__noise {
  opacity: 0.08;
  background-image:
    radial-gradient(circle at 20% 20%, rgba(255,255,255,0.35) 0.4px, transparent 0.7px),
    radial-gradient(circle at 70% 40%, rgba(255,255,255,0.25) 0.4px, transparent 0.8px),
    radial-gradient(circle at 40% 70%, rgba(255,255,255,0.2)  0.4px, transparent 0.8px);
  background-size: 9px 9px, 13px 13px, 11px 11px;
  animation: noiseShift 0.4s steps(2) infinite;
}

.banner__sweep {
  background: linear-gradient(
    100deg,
    transparent 30%,
    rgba(141,252,60,0.09) 48%,
    rgba(255,255,255,0.14) 50%,
    rgba(141,252,60,0.09) 52%,
    transparent 70%
  );
  width: 40%;
  left: -45%;
  animation: sweep 9.5s linear infinite;
  filter: blur(10px);
  opacity: 0.45;
}

/* ── HUD (textes décoratifs coins) ──────────────────────────────── */
.banner__hud {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.banner__hud::before {
  content: "BOOT / GATEWAY / NODE";
  position: absolute;
  top: 14px; left: 18px;
  font-size: clamp(8px, 0.9vw, 11px);
  letter-spacing: 0.24em;
  color: rgba(141,252,60,0.68);
  text-shadow: 0 0 10px rgba(141,252,60,0.22);
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

.banner__hud::after {
  content: "SELF-HOSTED // DEVOPS // GAMING";
  position: absolute;
  right: 18px; bottom: 14px;
  font-size: clamp(8px, 0.9vw, 11px);
  letter-spacing: 0.24em;
  color: rgba(141,252,60,0.5);
  text-align: right;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

/* ── Coins décoratifs ───────────────────────────────────────────── */
.banner__corner {
  position: absolute;
  height: 8px;
  width: clamp(80px, 14vw, 220px);
  background: linear-gradient(90deg, rgba(141,252,60,0.8), rgba(141,252,60,0.18), transparent);
  top: clamp(16px, 4%, 36px);
  opacity: 0.8;
  pointer-events: none;
}

.banner__corner--left {
  left: clamp(16px, 3%, 32px);
  clip-path: polygon(0 0, 92% 0, 100% 100%, 0 100%);
}

.banner__corner--right {
  right: clamp(16px, 3%, 32px);
  transform: scaleX(-1);
  clip-path: polygon(0 0, 92% 0, 100% 100%, 0 100%);
}

/* ── Contenu principal ──────────────────────────────────────────── */
.banner__content {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  padding: clamp(16px, 4%, 40px) clamp(24px, 6%, 80px);
  text-align: center;
}

.banner__title-wrap {
  position: relative;
  display: inline-block;
  max-width: 100%;
}

.banner__title {
  position: relative;
  margin: 0;
  font-size: clamp(36px, 8vw, 156px);
  line-height: 0.88;
  font-weight: 900;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  font-style: italic;
  transform: skewX(-12deg);
  color: var(--kiwi);
  text-shadow:
    0 0 2px  rgba(255,255,255,0.7),
    0 0 8px  rgba(141,252,60,0.75),
    0 0 26px rgba(141,252,60,0.26),
    0 0 58px rgba(109,255,159,0.10);
  animation: baseFlicker 7s infinite;
  white-space: nowrap;
  font-family: Impact, 'Arial Narrow', Arial, sans-serif;
}

/* Couches glitch */
.banner__title::before,
.banner__title::after {
  content: attr(data-text);
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  font-family: inherit;
}

.banner__title::before {
  color: rgba(109,255,159,0.85);
  transform: translate(2px, 0);
  text-shadow: -2px 0 rgba(109,255,159,0.9);
  animation: glitchA 8s infinite steps(2, end);
}

.banner__title::after {
  color: rgba(196,255,120,0.75);
  transform: translate(-2px, 0);
  text-shadow: 2px 0 rgba(196,255,120,0.7);
  animation: glitchB 8s infinite steps(2, end);
}

/* Trait accent sous le titre */
.banner__accent {
  position: absolute;
  left: 50%;
  transform: translateX(-50%) skewX(-12deg);
  bottom: -8px;
  width: min(86%, 780px);
  height: 3px;
  background: linear-gradient(
    90deg,
    transparent 0,
    rgba(141,252,60,0.2) 8%,
    rgba(141,252,60,0.95) 50%,
    rgba(141,252,60,0.2) 92%,
    transparent 100%
  );
  box-shadow: 0 0 16px rgba(141,252,60,0.35);
}

/* Sous-titre */
.banner__subtitle {
  margin: clamp(14px, 2.5%, 24px) 0 0;
  font-size: clamp(10px, 1.3vw, 22px);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--muted);
  text-shadow: 0 0 14px rgba(141,252,60,0.12);
  white-space: nowrap;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

/* ── Animations ─────────────────────────────────────────────────── */
@keyframes sweep {
  0%   { transform: translateX(0);    }
  100% { transform: translateX(380%); }
}

@keyframes baseFlicker {
  0%, 94%, 100% { opacity: 1;    }
  95%           { opacity: 0.95; }
  96%           { opacity: 0.88; }
  97%           { opacity: 1;    }
  98%           { opacity: 0.93; }
  99%           { opacity: 1;    }
}

@keyframes glitchA {
  0%, 90%, 100% { opacity: 0; clip-path: inset(0 0 0 0); }
  91% { opacity: 0.65; clip-path: inset(12% 0 66% 0); }
  92% { opacity: 0.15; clip-path: inset(74% 0  8% 0); }
  93% { opacity: 0.55; clip-path: inset(38% 0 34% 0); }
  94% { opacity: 0;    clip-path: inset(0  0  0  0); }
}

@keyframes glitchB {
  0%, 90%, 100% { opacity: 0; clip-path: inset(0 0 0 0); }
  91.2% { opacity: 0.28; clip-path: inset(18% 0 54% 0); }
  92.2% { opacity: 0.62; clip-path: inset(64% 0 12% 0); }
  93.2% { opacity: 0.24; clip-path: inset(42% 0 30% 0); }
  94.2% { opacity: 0;    clip-path: inset(0  0  0  0); }
}

@keyframes noiseShift {
  0%   { transform: translate(0,     0);     }
  25%  { transform: translate(0.5px, -0.5px); }
  50%  { transform: translate(-0.5px, 0.5px); }
  75%  { transform: translate(0.5px,  0.5px); }
  100% { transform: translate(0,     0);     }
}

/* ── Accessibilité ──────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .banner__title,
  .banner__title::before,
  .banner__title::after,
  .banner__noise,
  .banner__sweep {
    animation: none !important;
  }
}

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 480px) {
  .banner__subtitle {
    letter-spacing: 0.12em;
    white-space: normal;
    word-break: break-word;
  }
  .banner__hud::before,
  .banner__hud::after {
    display: none; /* trop serré sur très petit écran */
  }
}
</style>
