---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar     from "../components/Navbar.astro";
import Hero       from "../components/Hero.astro";
import Cards      from "../components/Cards.astro";
import Footer     from "../components/Footer.astro";

const lang = "fr";
---

<BaseLayout
  title="Loïc Kergoat — Rookain | Portfolio DevOps"
  description="Portfolio self-hosted de Loïc Kergoat — infrastructure DevOps open source, reverse proxy, CI/CD, monitoring."
  lang={lang}
>
  <Navbar lang={lang} currentPath="/" />
  <main>
    <Hero  lang={lang} />
    <Cards lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>