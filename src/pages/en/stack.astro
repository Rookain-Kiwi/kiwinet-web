---
/**
 * en/stack.astro
 * Role  : Technical stack page (English version) — orchestrates StackArchDiagram, StackLayers and StackTable
 *         to document the Kiwinet infrastructure architecture and technical choices.
 * Props : none (static page)
 * Emits : none
 */
import BaseLayout       from "../../layouts/BaseLayout.astro";
import Navbar           from "../../components/Navbar.astro";
import Footer           from "../../components/Footer.astro";
import StackArchDiagram from "../../components/StackArchDiagram.astro";
import StackLayers      from "../../components/StackLayers.astro";
import StackTable       from "../../components/StackTable.astro";

const lang = "en";
---

<BaseLayout
  title="Tech stack"
  description="Architecture and technical choices behind the Kiwinet self-hosted infrastructure"
  lang={lang}
>
  <Navbar lang={lang} currentPath="/en/stack" />

  <main>
    <section class="stack-header">
      <div class="container">
        <h1 class="stack-title">Tech stack</h1>
        <p class="stack-intro">
          This infrastructure is fully self-hosted on a home ARM64 VM.
          Every tool was chosen for three reasons: open source, representative
          of real-world industry standards, and consistent with the rest of the chain.
          This page documents the architecture and the choices behind it.
        </p>
      </div>
    </section>

    <section class="stack-content">
      <div class="container">
        <StackArchDiagram lang={lang} />
        <StackLayers      lang={lang} />
        <StackTable       lang={lang} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
.stack-header {
  padding: 48px 0 32px;
  border-bottom: 1px solid var(--color-border);
}

.stack-title {
  font-size: 28px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 12px;
}

.stack-intro {
  font-size: 15px;
  line-height: 1.7;
  color: var(--color-text-secondary);
  max-width: 680px;
}

.stack-content {
  padding: 40px 0 56px;
}
</style>
