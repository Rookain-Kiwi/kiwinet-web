---
/**
 * index.astro
 * Rôle : Page d'accueil (version française) — assemble Navbar, Hero (bannière cyber), Cards (navigation) et Footer.
 * Reçoit : aucune prop (page statique)
 * Émet   : aucun
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar     from "../components/Navbar.astro";
import Hero       from "../components/Hero.astro";
import Cards      from "../components/Cards.astro";
import Footer     from "../components/Footer.astro";

const lang = "fr";
---

<BaseLayout
  title="kiwinet.me — DevOps, Gaming and... Kiwis"
  description="Infrastructure self-hosted open source — reverse proxy, CI/CD, monitoring, gaming. Propulsé par kiwinet.me."
  lang={lang}
>
  <Navbar lang={lang} currentPath="/" />
  <main>
    <Hero lang={lang} />
    <Cards lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
