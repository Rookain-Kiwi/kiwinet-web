---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar     from "../components/Navbar.astro";
import Hero       from "../components/Hero.astro";
import Footer     from "../components/Footer.astro";

const lang = "fr";
---

<BaseLayout
  title="kiwinet.me — DevOps, Gaming and... Kiwis"
  description="Infrastructure self-hosted open source — reverse proxy, CI/CD, monitoring, gaming. Propulsé par kiwinet.me."
  lang={lang}
>
  <Navbar lang={lang} currentPath="/" />
  <main>
    <Hero lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
