---
/**
 * BaseLayout.astro
 * Rôle : Layout HTML de base — fournit le <head> complet (meta, favicon, fonts) et le <body> avec slot
 *        pour injecter le contenu de chaque page.
 * Reçoit : title?: string — titre de l'onglet (défaut : "Kiwinet")
 *          description?: string — meta description SEO (défaut : "Self-hosted website / Open source DevOps infrastructure")
 *          lang?: string — attribut lang de la balise <html> pour l'accessibilité (défaut : "fr")
 * Émet   : <slot /> — point d'injection du contenu de la page
 */
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = "Kiwinet",
  description = "Self-hosted website / Open source DevOps infrastructure",
  lang = "fr",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /><!-- crossorigin requis pour les ressources fonts cross-origin -->
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>